{
    "compilerOptions": {
        "module": "commonjs",
        "lib": ["es2015", "es2017", "dom"],
        "target": "es5",
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "outDir": "temp/ts-cache",
        "allowSyntheticDefaultImports": true,
        "strict": false,
        "noImplicitAny": false
    },
    "include": [
        "assets/**/*.ts",
        "creator.d.ts"
    ],
    "exclude": [
        "node_modules",
        "library",
        "local",
        "temp",
        "build",
        "settings"
    ]
}
